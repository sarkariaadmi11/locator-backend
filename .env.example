# --- Core (required) ---
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/locator_db?schema=public"
JWT_SECRET="replace-with-a-random-string-at-least-32-characters-long"

# --- Core (optional, defaults shown) ---
JWT_EXPIRES_IN="7d"
ACCESS_TOKEN_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_DAYS=30
CORS_ORIGIN="http://localhost:8081"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
UPLOAD_DIR="uploads"
# OTP_EXPIRES_MINUTES=10
# PHONE_OTP_EXPIRES_SECONDS=60
# PHONE_OTP_MAX_ATTEMPTS=3
# PHONE_OTP_LOCKOUT_MINUTES=5
# PHONE_OTP_RESEND_COOLDOWN_SECONDS=30

# --- MSG91 (optional — falls back to console-logged phone OTPs outside production;
# required in production) ---
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# --- Dev-only mock OTP (temporary, not in PRD/TRD) — forces every phone OTP to a fixed
# 123456 and skips the real MSG91 SMS send, so signup/login work with no SMS gateway keys
# during development. Hard-disabled outside NODE_ENV=development regardless of this value.
# Comment out (or delete) once MSG91_AUTH_KEY/MSG91_SENDER_ID are set — real OTPs resume
# automatically, no other change needed.
MOCK_OTP=true

# --- Brevo (optional — falls back to console-logged OTPs outside production;
# required in production. If Brevo returns 401 Unauthorized, check the
# "Authorized IPs" restriction on the API key in the Brevo dashboard.) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# --- Cloudinary (required — image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Razorpay (required — wallet top-up/withdraw) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Redis (required — Creator mutex lock, PRD §5.5) ---
REDIS_URL="redis://127.0.0.1:6379"
# Acceptance timer window a Creator has to start recording before auto-release (PRD §5.5 [REVIEW]).
ACCEPTANCE_TIMER_MINUTES=15

# --- Admin bootstrap (required — auto-seeded on first boot) ---
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# --- Firebase (optional — push notifications disabled if unset/missing file) ---
FIREBASE_SERVICE_ACCOUNT_PATH="firebase-service-account.json"
