# --- Core (required) ---
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/locator_db?schema=public"
JWT_SECRET="replace-with-a-random-string-at-least-32-characters-long"

# --- Core (optional, defaults shown) ---
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:8081"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
UPLOAD_DIR="uploads"
# OTP_EXPIRES_MINUTES=10

# --- Cloudinary (required — image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Brevo (optional — falls back to console-logged OTPs outside production;
# required in production. If Brevo returns 401 Unauthorized, check the
# "Authorized IPs" restriction on the API key in the Brevo dashboard.) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# --- Razorpay (required — wallet top-up/withdraw) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Redis (required — Creator mutex lock, PRD §5.5) ---
REDIS_URL="redis://127.0.0.1:6379"
# Acceptance timer window a Creator has to start recording before auto-release (PRD §5.5 [REVIEW]).
ACCEPTANCE_TIMER_MINUTES=15

# --- Admin bootstrap (required — auto-seeded on first boot) ---
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# --- Firebase (optional — push notifications disabled if unset/missing file) ---
FIREBASE_SERVICE_ACCOUNT_PATH="firebase-service-account.json"
